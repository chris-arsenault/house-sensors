        {
          "query": "-- Estimate line resistance R ≈ ΔV / ΔI during load steps\nSELECT (\"dV\" / \"dI\") AS \"R_est_ohm\", \"dV\", \"dI\"\nFROM (\n  SELECT DIFFERENCE(MEAN(\"voltage\")) AS \"dV\",\n         DIFFERENCE(MEAN(\"current\")) AS \"dI\"\n  FROM \"voltage_monitoring\"\n  WHERE $timeFilter\n GROUP BY time($__interval), \"device_name\"::tag\n)\nWHERE (\"dI\" > 0.5 OR \"dI\" < -0.5)   -- ignore tiny/noisy steps\nORDER BY time DESC\n",
